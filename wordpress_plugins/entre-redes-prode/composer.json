{
    "name": "entre-redes/prode-interno",
    "description": "WordPress plugin: authenticated predictions game for the Entre Redes football league",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0",
        "firebase/php-jwt": "^6.10",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "EntreRedes\\Prode\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EntreRedes\\Prode\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
